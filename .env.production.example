# Copier vers `.env.production` à la racine du dépôt (à côté de docker-compose.prod.yml).
# docker compose lit ce fichier automatiquement (env_file) — plus besoin de `--env-file` en ligne de commande.

NODE_ENV=production

POSTGRES_USER=eventnow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=eventnow_db
DATABASE_URL=postgresql://eventnow:change-me@postgres:5432/eventnow_db?schema=public

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=change-me-super-secret-jwt-key
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

FRONTEND_URL=https://eventnow.fr
# Toujours lister apex + www si les deux pointent vers le site (emails : une seule URL dans FRONTEND_URL).
CORS_ORIGINS=https://eventnow.fr,https://www.eventnow.fr
VITE_API_URL=https://eventnow.fr

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://eventnow.fr/api/v1/auth/google/callback

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=you@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@example.com

# Stripe Production - Récupérer les clés depuis https://dashboard.stripe.com/apikeys
# IMPORTANT : Utiliser les clés LIVE (sk_live_xxx et pk_live_xxx) pour la production
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Webhook secret : créer un webhook endpoint sur https://dashboard.stripe.com/webhooks
# et pointer vers https://eventnow.fr/api/v1/orders/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Optionnel : domaines supplémentaires à autoriser dans la CSP pour la 3DS (séparés par des virgules)
# Exemple: https://api-m.banque-exemple.fr,https://acs.banque-exemple.fr
STRIPE_CSP_EXTRA_HOSTS=
