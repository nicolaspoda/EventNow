// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ORGANIZER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
  REFUND_REQUESTED
}

enum EventType {
  PROFESSIONAL
  COMMUNITY
}

enum ParticipationRequestStatus {
  PENDING
  ACCEPTED
  REFUSED
}

enum EventCategory {
  CONCERT
  CONFERENCE
  FESTIVAL
  SPORT
  THEATER
  EXHIBITION
  OTHER
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ReportType {
  EVENT
  USER
}

enum ReportReason {
  INAPPROPRIATE_CONTENT
  SPAM
  FAKE_EVENT
  HARASSMENT
  SCAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ItemStatus {
  UNCLAIMED
  CLAIMED
}

enum PollStatus {
  OPEN
  CLOSED
}

enum StaffInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model User {
  id               String   @id @default(uuid())
  username         String?  @unique
  email            String   @unique
  passwordHash     String?  @map("password_hash")
  googleId         String?  @unique @map("google_id")
  avatarUrl        String?  @map("avatar_url")
  organizationName String?  @map("organization_name")
  role             Role     @default(USER)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organizedEvents Event[]
  bookings        Booking[]
  orders          Order[]
  reviews         Review[]
  participationRequests ParticipationRequest[]
  notifications   Notification[]
  participantReviewsGiven ParticipantReview[] @relation("ReviewAuthor")
  participantReviewsReceived ParticipantReview[] @relation("ReviewedParticipant")

  createdPromoCodes PromoCode[]

  followers  Follow[] @relation("Follower")
  following Follow[] @relation("Following")

  conversationMemberships ConversationMember[]
  sentMessages            Message[]
  staffInvitationsSent    StaffInvitation[] @relation("InvitationSender")
  staffInvitationsReceived StaffInvitation[] @relation("InvitationReceiver")
  eventStaffAssignments   EventStaff[]

  reportsMade     Report[] @relation("ReportsMade")
  reportsReceived Report[] @relation("ReportsReceived")

  claimedItems EventItem[] @relation("ItemsClaimed")
  addedItems   EventItem[] @relation("ItemsAdded")

  pollsCreated Poll[]     @relation("PollsCreated")
  pollVotes    PollVote[]

  @@index([username])
  @@map("users")
}

model Event {
  id          String        @id @default(uuid())
  title       String
  description String?
  location    String
  address     String?
  city        String?
  postalCode  String?       @map("postal_code")
  country     String?       @default("France")
  latitude    Float?
  longitude   Float?
  imageUrl    String?       @map("image_url")
  imagePublicId String?      @map("image_public_id")
  galleryImages Json?        @map("gallery_images")
  eventDate   DateTime      @map("event_date")
  endDate     DateTime?     @map("end_date")
  cancelledAt DateTime?     @map("cancelled_at")
  cancelReason String?      @map("cancel_reason") @db.Text
  organizerId String        @map("organizer_id")
  type        EventType     @default(PROFESSIONAL)
  category    EventCategory @default(OTHER)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  organizer        User             @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  ticketCategories TicketCategory[]
  reviews          Review[]
  participationRequests ParticipationRequest[]
  staffAssignments EventStaff[]
  staffInvitations StaffInvitation[]
  promoCodes       PromoCode[]
  reports          Report[]
  itemList         EventItemList?
  polls            Poll[]

  @@index([organizerId])
  @@index([eventDate])
  @@index([type, category, eventDate])
  @@index([location])
  @@index([city])
  @@index([latitude, longitude])
  @@map("events")
}

model TicketCategory {
  id           String   @id @default(uuid())
  eventId      String   @map("event_id")
  name         String
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  initialStock Int      @map("initial_stock")
  currentStock Int      @map("current_stock")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookings Booking[]
  tickets  Ticket[]

  @@index([eventId])
  @@index([eventId, currentStock])
  @@map("ticket_categories")
}

model Booking {
  id               String        @id @default(uuid())
  userId           String        @map("user_id")
  ticketCategoryId String        @map("ticket_category_id")
  quantity         Int
  status           BookingStatus @default(PENDING)
  expiresAt        DateTime      @map("expires_at")
  orderId          String?       @unique @map("order_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketCategory TicketCategory @relation(fields: [ticketCategoryId], references: [id], onDelete: Cascade)
  order          Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ticketCategoryId])
  @@index([status])
  @@index([expiresAt])
  @@index([orderId])
  @@map("bookings")
}

model Order {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  paymentIntentId String?     @map("payment_intent_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tickets  Ticket[]
  bookings Booking[]

  @@index([userId])
  @@index([status])
  @@index([paymentIntentId])
  @@map("orders")
}

model Ticket {
  id               String    @id @default(uuid())
  orderId          String    @map("order_id")
  ticketCategoryId String    @map("ticket_category_id")
  qrCode           String    @unique @map("qr_code")
  validatedAt      DateTime? @map("validated_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketCategory TicketCategory @relation(fields: [ticketCategoryId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([qrCode])
  @@index([validatedAt])
  @@map("tickets")
}

model ParticipationRequest {
  id          String                   @id @default(uuid())
  eventId     String                   @map("event_id")
  userId      String                   @map("user_id")
  message     String?                  @db.Text
  status      ParticipationRequestStatus @default(PENDING)
  respondedAt DateTime?                @map("responded_at")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@map("participation_requests")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String   @db.Text
  read      Boolean  @default(false)
  relatedId String?  @map("related_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  notificationsEnabled Boolean @default(true) @map("notifications_enabled")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Review {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId], name: "event_id_user_id")
  @@index([eventId])
  @@index([userId])
  @@map("reviews")
}

model ParticipantReview {
  id             String   @id @default(uuid())
  eventId        String   @map("event_id")
  reviewerId     String   @map("reviewer_id")
  participantId  String   @map("participant_id")
  rating         Int
  comment        String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  reviewer    User @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)
  participant User @relation("ReviewedParticipant", fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([eventId, reviewerId, participantId])
  @@index([eventId])
  @@index([reviewerId])
  @@index([participantId])
  @@map("participant_reviews")
}

enum ConversationType {
  DIRECT
  GROUP
  EVENT
}

model Conversation {
  id        String           @id @default(uuid())
  type      ConversationType @default(DIRECT)
  name      String?
  imageUrl  String?          @map("image_url")
  eventId   String?          @map("event_id")
  createdBy String?          @map("created_by")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  members  ConversationMember[]
  messages Message[]

  @@index([type])
  @@index([eventId])
  @@index([createdBy])
  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  joinedAt       DateTime @default(now()) @map("joined_at")
  lastReadAt     DateTime @default(now()) @map("last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

model StaffInvitation {
  id          String                @id @default(uuid())
  email       String
  token       String                @unique
  eventId     String                @map("event_id")
  invitedById String                @map("invited_by_id")
  acceptedById String?              @map("accepted_by_id")
  status      StaffInvitationStatus @default(PENDING)
  expiresAt   DateTime              @map("expires_at")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  event       Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitedBy   User   @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy  User?  @relation("InvitationReceiver", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([token])
  @@index([eventId])
  @@index([invitedById])
  @@index([status])
  @@map("staff_invitations")
}

model EventStaff {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_staff")
}

model PromoCode {
  id            String       @id @default(cuid())
  code          String
  eventId       String       @map("event_id")
  createdById   String       @map("created_by_id")
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(10, 2)
  maxUses       Int?         @map("max_uses")
  currentUses   Int          @default(0) @map("current_uses")
  expiresAt     DateTime?    @map("expires_at")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id])

  @@unique([code, eventId])
  @@index([eventId])
  @@index([createdById])
  @@index([code])
  @@map("promo_codes")
}

model Report {
  id            String       @id @default(cuid())
  reporterId    String       @map("reporter_id")
  reporter      User         @relation("ReportsMade", fields: [reporterId], references: [id])
  type          ReportType
  reason        ReportReason
  description   String?      @db.Text
  status        ReportStatus @default(PENDING)
  targetUserId  String?      @map("target_user_id")
  targetUser    User?        @relation("ReportsReceived", fields: [targetUserId], references: [id])
  targetEventId String?      @map("target_event_id")
  targetEvent   Event?       @relation(fields: [targetEventId], references: [id])
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@unique([reporterId, type, targetUserId])
  @@unique([reporterId, type, targetEventId])
  @@index([reporterId])
  @@index([status])
  @@map("reports")
}

model EventItemList {
  id        String      @id @default(cuid())
  eventId   String      @unique @map("event_id")
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  items     EventItem[]

  @@map("event_item_lists")
}

model EventItem {
  id          String        @id @default(cuid())
  listId      String        @map("list_id")
  list        EventItemList @relation(fields: [listId], references: [id], onDelete: Cascade)
  name        String
  quantity    Int           @default(1)
  unit        String?
  note        String?       @db.Text
  status      ItemStatus    @default(UNCLAIMED)
  claimedById String?       @map("claimed_by_id")
  claimedBy   User?         @relation("ItemsClaimed", fields: [claimedById], references: [id])
  addedById   String        @map("added_by_id")
  addedBy     User          @relation("ItemsAdded", fields: [addedById], references: [id])
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([listId])
  @@map("event_items")
}

model Poll {
  id             String       @id @default(cuid())
  eventId        String       @map("event_id")
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdById    String       @map("created_by_id")
  createdBy      User         @relation("PollsCreated", fields: [createdById], references: [id])
  question       String       @db.Text
  description    String?      @db.Text
  status         PollStatus   @default(OPEN)
  multipleChoice Boolean      @default(false) @map("multiple_choice")
  closesAt       DateTime?    @map("closes_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  options        PollOption[]
  votes          PollVote[]

  @@index([eventId])
  @@index([createdById])
  @@map("polls")
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String     @map("poll_id")
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text      String
  order     Int        @default(0)
  createdAt DateTime   @default(now()) @map("created_at")
  votes     PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String     @map("poll_id")
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String     @map("option_id")
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now()) @map("created_at")

  @@unique([pollId, optionId, userId])
  @@index([pollId])
  @@index([userId])
  @@map("poll_votes")
}
