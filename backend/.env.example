NODE_ENV=development

DATABASE_URL="postgresql://user:password@localhost:5432/eventnow?schema=public"

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-production
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

LOG_LEVEL=info

THROTTLE_TTL=60
THROTTLE_LIMIT=10

PORT=3000

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=noreply@eventnow.com

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CSP_EXTRA_HOSTS=

# Sentry (suivi d'erreurs) — actif uniquement si NODE_ENV=production ET cette
# variable est renseignée ; laisser vide en dev, aucun effet de bord sinon.
# Récupérer le DSN : compte gratuit sur https://sentry.io > New Project >
# plateforme "Node.js" (NestJS) > copier le DSN affiché à la création.
SENTRY_DSN=
