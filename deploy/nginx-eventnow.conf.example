# Exemple pour le VPS : reverse-proxy HTTPS (Certbot) → frontend (5173) + API (3000).
# À fusionner avec les blocs déjà générés par Certbot (chemins ssl_certificate, etc.).
#
# Socket.IO (messagerie) : le client appelle wss://eventnow.fr/socket.io/ (même origine que
# VITE_API_URL). Sans le bloc `location /socket.io/` ci-dessous, Nginx envoie /socket.io
# vers le frontend (5173) au lieu du backend → erreurs WebSocket en console.
# Optionnel dans http { } (recommandé pour le fallback polling) :
#   map $http_upgrade $connection_upgrade {
#       default upgrade;
#       ''      close;
#   }
# Puis remplacer `Connection "upgrade"` par `Connection $connection_upgrade`.
#
# Vérifier l’API depuis le VPS : curl -fsS http://127.0.0.1:3000/api/v1/health
# Si 502 sur /api/ ou WebSocket : docker compose ps ; docker compose logs backend --tail=80
# CORS / Socket.IO : si les utilisateurs utilisent www, le backend doit autoriser
# https://www.eventnow.fr (voir CORS_ORIGINS dans docker-compose.prod.yml).
#
# Erreurs fréquentes vues en prod :
# - Oublier un `}` : le 2e bloc server ne doit PAS être imbriqué dans le 1er.
# - Typo server_name (ex. eventnow.frventnow.fr).
# - Amont 5173 : si `docker compose logs frontend` affiche « Local: https://… »,
#   Nginx doit utiliser `proxy_pass https://127.0.0.1:5173` + `proxy_ssl_verify off`.
#   Après rebuild du front avec le vite.config actuel (preview en HTTP), utiliser
#   `proxy_pass http://127.0.0.1:5173` à la place.

server {
    listen 443 ssl;
    server_name eventnow.fr www.eventnow.fr;

    ssl_certificate /etc/letsencrypt/live/eventnow.fr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/eventnow.fr/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # CSP compatible Stripe (Payment Element + page de confirmation paiement).
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://js.stripe.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.stripe.com https://q.stripe.com https://r.stripe.com https://m.stripe.com; frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://*.stripe.com; child-src 'self' https://js.stripe.com https://hooks.stripe.com https://*.stripe.com; font-src 'self' data: https:; worker-src 'self' blob:; form-action 'self' https://js.stripe.com https://hooks.stripe.com https://*.stripe.com https://api.stripe.com; frame-ancestors 'self';" always;
    add_header Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(self)" always;

    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # NestJS + Socket.IO (doit être avant `location /`)
    location /socket.io/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
        proxy_buffering off;
    }

    # Si le preview Vite est encore en HTTPS (ancienne image) :
    #   proxy_pass https://127.0.0.1:5173;
    #   proxy_ssl_verify off;
    # Vite 7 (preview) : sans `preview.allowedHosts` pour le domaine public, un Host
    # type eventnow.fr peut renvoyer 403. Soit tu listes le domaine dans vite.config,
    # soit tu forces Host vers l’amont local :
    #   proxy_set_header Host 127.0.0.1;
    location / {
        proxy_pass http://127.0.0.1:5173;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 443 ssl;
    server_name api.eventnow.fr;

    ssl_certificate /etc/letsencrypt/live/eventnow.fr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/eventnow.fr/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
